<% layout("/layout/boilerplate")%>   
   <style>
      #filters{
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        
      }

      .filter{
        padding-top: 1.5rem;
        text-align: center;
        margin-right: 1.5rem;
        cursor: pointer;
        opacity: 0.75;
      }

      .filter:hover{
        opacity: 1;
      }

      #tax-info{
        display: none;
      }

      .tax-toggle{
        margin-left: 2rem;
        padding: 1rem;
        border: 1px solid black;
        border-radius: 1rem;
        height: 3rem;
        display: flex;
        align-items: center;
      }
   </style>
     
    <div id="filters">
        <a href="/listings?category=Trending" class="filter">
          <div><i class="fa-solid fa-fire"></i></div>
          <p>Trending</p>
        </a>
        
        <a href="/listings?category=Iconic Cities" class="filter">
          <div><i class="fa-solid fa-city"></i></div>
          <p>Iconic Cities</p>
        </a>
        <a href="/listings?category=Beach" class="filter">
          <div><i class="fa-solid fa-umbrella-beach"></i></div>
          <p>Beach</p>
        </a>
        <a href="/listings?category=Mountain" class="filter">
          <div><i class="fa-solid fa-mountain-city"></i></div>
          <p>Mountain</p>
        </a>
        <a href="/listings?category=Farms" class="filter">
          <div><i class="fa-brands fa-canadian-maple-leaf"></i></div>
          <p>Farms</p>
        </a>
        <a href="/listings?category=Camping" class="filter">
          <div><i class="fa-brands fa-free-code-camp"></i></div>
          <p>Camping</p>
        </a>
        <a href="/listings?category=Family house" class="filter">
          <div><i class="fa-solid fa-people-roof"></i></div>
          <p>Family house</p>
        </a>
        <a href="/listings?category=Castles" class="filter">
          <div><i class="fa-brands fa-fort-awesome"></i></div>
          <p>Castles</p>
        </a>
        <a href="/listings?category=Artic" class="filter">
          <div><i class="fa-regular fa-snowflake"></i></div>
          <p>Artic</p>
        </a>
        <a href="/listings?category=Amusement parks" class="filter">
          <div><i class="fa-solid fa-road-barrier"></i></div>
          <p>Amusement parks</p>
        </a>
        <a href="/listings?category=Historical" class="filter">
            <div><i class="fa-solid fa-landmark"></i></div>
            <p>Historical</p>
        </a> 
     
 
      <div class="tax-toggle">
        <div class="form-check-reverse form-switch">
          <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
          <label class="form-check-label" for="switchCheckDefault">Display Taxes</label>
</div>
      </div>
    </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
     <% for(let listing of allListing){ %>
        <a href="/listings/<%= listing._id %>" class="listing-link">
          <div class="cards col listing-card"  >
            <img 
             src="<%= listing.image.url %>" 
             class="card-img-top" 
             alt=" listing_img " 
             style="height: 20rem;"
             />
            <div class="card-img-overlay"></div>
            <div class="card-body">
              <p class="card-text">
                <%= listing.title %></p>
              <p class="card-text"> &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %>  /night <i id="tax-info"> &nbsp; &nbsp;+18% GST</i></p>
              
        </div>
    </div>
    </a>
     <% } %>
</div>

<script>
  let taxswitch = document.getElementById('switchCheckDefault');
  taxswitch.addEventListener('change', function() {
    let taxinfo = document.querySelectorAll('#tax-info');
    taxinfo.forEach(function(element) {
      if (taxswitch.checked) {
        element.style.display = 'inline';
      } else {
        element.style.display = 'none';
      }
    });
  });
</script>
    
   

